{% extends "template.njk" %}

{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "govuk/components/tag/macro.njk" import govukTag %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{% from "macros/csrf.njk" import csrfProtection %}

{% block pageTitle %}Delete task - Manage tasks{% endblock %}

{% block beforeContent %}
  {{ govukBackLink({ text: "Back to task", href: "/tasks/" + task.id }) }}
{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-xl">Are you sure you want to delete this task?</h1>

      {% set s = statusPresentation(task.status) %}
      {% set statusHtml %}{{ govukTag({ text: s.label, classes: "govuk-tag--" + s.colour }) }}{% endset %}
      {{ govukSummaryList({
        rows: [
          { key: { text: "Title" }, value: { text: task.title } },
          { key: { text: "Status" }, value: { html: statusHtml } },
          { key: { text: "Due date" }, value: { text: task.dueDateTime | formatDateTime } }
        ]
      }) }}

      <p class="govuk-body">This cannot be undone.</p>

      <form method="post" action="/tasks/{{ task.id }}/delete" novalidate>
        {{ csrfProtection(csrfToken) }}
        <div class="govuk-button-group">
          {{ govukButton({ text: "Delete task", classes: "govuk-button--warning" }) }}
          <a class="govuk-link" href="/tasks/{{ task.id }}">Cancel</a>
        </div>
      </form>
    </div>
  </div>
{% endblock %}
